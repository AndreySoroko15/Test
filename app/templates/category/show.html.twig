{% extends 'base.html.twig' %}

{% block title %}BookCategory{% endblock %}

{% block body %}
    <h1>BookCategory</h1>

    <div class="float-end">
        <a class="btn btn-warning"
           href="{{ path('app_category_edit', {'id': category.id}) }}">
            <i class="bi bi-pencil"></i>
        </a>

        <div class="float-end">
            {{ include('category/_delete_form.html.twig') }}
        </div>
    </div>

    {{ include('components/_flash.html.twig') }}

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ category.id }}</td>
            </tr>
            <tr>
                <th>Title</th>
                <td>{{ category.title }}</td>
            </tr>
            <tr>
                <th>Published</th>
                <td>{{ category.publishedAt ? category.publishedAt|date('Y-m-d') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a class="btn btn-light" href="{{ path('app_category_index') }}">back to list</a>
{% endblock %}
