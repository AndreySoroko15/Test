{% extends 'base.html.twig' %}

{% block title %}BookCategory index{% endblock %}

{% block body %}
    <h1>BookCategory index</h1>

    <a href="{{ path('app_category_new') }}" class="btn btn-secondary float-end">Create new</a>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Title</th>
                <th>PublishedAt</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for category in pagination %}
            <tr>
                <td>{{ category.id }}</td>
                <td>{{ category.title }}</td>
                <td>{{ category.publishedAt ? category.publishedAt|date('Y-m-d') : '' }}</td>
                <td>
                    <div class="d-flex gap-1">
                        <a class="btn btn-sm btn-primary" href="{{ path('app_category_show', {'id': category.id}) }}"><i class="bi bi-eye"></i></a>
                        <a class="btn btn-sm btn-warning" href="{{ path('app_category_edit', {'id': category.id}) }}"><i class="bi bi-pencil"></i></a>
                    </div>
                </td>

            </tr>
        {% else %}
            <tr>
                <td colspan="7">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <div class="navigation float-end">
        {{ knp_pagination_render(pagination) }}
    </div>
{% endblock %}
